<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_booking_action" model="ir.actions.act_window">
        <field name="name">Booking</field>
        <field name="res_model">freight.booking</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="booking_menu" name="Booking" action="freight_booking_action" sequence="5" parent="bi_freight_management.freight_menu_action"/>

    <record id="freight_booking_view_form" model="ir.ui.view">
        <field name="name">freight.booking.form</field>
        <field name="model">freight.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_convert_shipment" type="object" string="Convert Shipment" class="btn-primary"/>
                    <field name="stage" widget="statusbar" class="o_field_statusbar" options="{'clickable': '1', 'fold_field': 'fold'}"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_shipment" type="object" class="oe_stat_button" invisible="freight_operation_id == False" icon="fa-truck">
                            <div class="o_field_widget o_stat_info">
                                <field name="freight_operation_id" invisible="1"/>
                                <span class="o_stat_text">Shipment</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title oe_inline">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="direction" widget="radio" options="{'vertical': true}"/>
                        </group>
                        <group>
                            <field name="transport" widget="radio" options="{'vertical': true}"/>
                        </group>
                        <group>
                            <field name="operation" widget="radio" options="{'vertical': true}"/>
                        </group>
                        <group>
                            <field name="ocean_shipment_type" widget="radio" options="{'vertical': true}" invisible="transport != 'ocean'"/>
                            <field name="inland_shipment_type" widget="radio" options="{'vertical': true}" invisible="transport != 'land'"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <div class="oe_title oe_inline">
                                <h4>Shipper</h4>
                            </div>
                        </group>
                        <group>
                            <div class="oe_title oe_inline">
                                <h4>Consignee</h4>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="shipper_id"/>
                        </group>
                        <group>
                            <field name="consignee_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <div class="oe_inline">
                                <h4>Main Carriage</h4>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="from_port_id" invisible="transport != 'land'" required="transport == 'land'"/>
                            <field name="loading_port_id" invisible="transport != 'ocean'" required="transport == 'ocean'"/>
                            <field name="gateway_id" invisible="transport != 'air'" required="transport == 'air'"/>
                            <field name="mawb_no" invisible="transport != 'air'"/>
                            <field name="shipping_line_id" invisible="transport != 'ocean'"/>
                            <field name="voyage_no" invisible="transport != 'ocean'"/>
                            <field name="vessel_id" invisible="transport != 'ocean'"/>
                            <field name="obl" invisible="transport != 'ocean'"/>
                        </group>
                        <group>
                            <field name="to_port_id" invisible="transport != 'land'" required="transport == 'land'"/>
                            <field name="discharge_port_id" invisible="transport != 'ocean'" required="transport == 'ocean'"/>
                            <field name="destination_id" invisible="transport != 'air'" required="transport == 'air'"/>
                            <field name="airline_id" invisible="transport != 'air'"/>
                            <field name="flight_no" invisible="transport != 'air'"/>
                            <field name="date"/>
                            <field name="cmr_rwb_pro" invisible="transport != 'land'"/>
                            <field name="trucker_id" invisible="transport != 'land'"/>
                            <field name="trucker_no" invisible="transport != 'land'"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <div class="oe_title oe_inline">
                                <h4>General</h4>
                            </div>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="barcode"/>
                            <field name="agent_id"/>
                            <field name="user_id"/>
                            <field name="freight_pc_id"/>
                            <field name="freight_other_pc_id"/>
                            <field name="file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="dangerous_goods"/>
                            <field name="move_type_id"/>
                            <field name="tracking_no"/>
                            <field name="incoterm_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_booking_view_tree" model="ir.ui.view">
        <field name="name">freight.booking.tree</field>
        <field name="model">freight.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="direction"/>
                <field name="operation"/>
                <field name="transport"/>
                <field name="shipper_id"/>
                <field name="consignee_id"/>
                <field name="gateway_id"/>
                <field name="destination_id"/>
                <field name="agent_id"/>
                <field name="user_id"/>
                <field name="dangerous_goods"/>
                <field name="barcode"/>
            </list>
        </field>
    </record>

    <record id="freight_booking_view_kanban" model="ir.ui.view">
        <field name="name">freight.booking.kanban</field>
        <field name="model">freight.booking</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" create="1" class="o_kanban_small_column" quick_create="false" archivable="false" sample="1">
                <field name="name"/>
                <field name="direction"/>
                <field name="transport"/>
                <field name="user_id"/>
                <field name="operation"/>
                <field name="date"/>
                <field name="stage"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <br/>
                            <strong>
                                <field name="direction"/>
                            </strong>
                            <div> Operation -
                                <strong>
                                    <field name="operation"/>
                                </strong>
                            </div>
                            <div>
                                Transport By
                                <strong>
                                    <field name="transport"/>
                                </strong>
                            </div>
                            <div class="oe_kanban_footer">
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        Date:
                                        <field name="date"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>