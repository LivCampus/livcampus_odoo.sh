<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_vessel_action" model="ir.actions.act_window">
        <field name="name">Vessels</field>
        <field name="res_model">freight.vessel</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="freight_vessel_menu" name="Vessels" action="freight_vessel_action"
              parent="bi_freight_management.configuration_menu" sequence="20"/>

    <record id="freight_vessel_view_form" model="ir.ui.view">
        <field name="name">freight.vessel.form</field>
        <field name="model">freight.vessel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="country_id"/>
                            <field name="global_zone_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_vessel_view_tree" model="ir.ui.view">
        <field name="name">freight.vessel.tree</field>
        <field name="model">freight.vessel</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="global_zone_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

</odoo>