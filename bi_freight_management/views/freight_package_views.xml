<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_package_action" model="ir.actions.act_window">
        <field name="name">Packages</field>
        <field name="res_model">freight.package</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="freight_package_menu" name="Packages" action="freight_package_action"
              parent="bi_freight_management.configuration_menu" sequence="50"/>

    <record id="freight_package_view_form" model="ir.ui.view">
        <field name="name">freight.package.form</field>
        <field name="model">freight.package</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="is_container"/>
                            <field name="refrigerate"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="size"/>
                            <field name="volume"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_package_view_tree" model="ir.ui.view">
        <field name="name">freight.package.tree</field>
        <field name="model">freight.package</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="is_container"/>
                <field name="refrigerate"/>
                <field name="size"/>
                <field name="volume"/>
                <field name="active"/>
            </list>
        </field>
    </record>

</odoo>