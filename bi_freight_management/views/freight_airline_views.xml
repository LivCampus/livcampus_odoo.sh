<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_airline_action" model="ir.actions.act_window">
        <field name="name">Airline</field>
        <field name="res_model">freight.airline</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="freight_airline_menu" name="Airline" action="freight_airline_action"
              parent="bi_freight_management.configuration_menu" sequence="30"/>

    <record id="freight_airline_view_form" model="ir.ui.view">
        <field name="name">freight.airline.form</field>
        <field name="model">freight.airline</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="country_id"/>
                            <field name="icao_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_airline_view_tree" model="ir.ui.view">
        <field name="name">freight.airline.tree</field>
        <field name="model">freight.airline</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="country_id"/>
                <field name="icao_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

</odoo>