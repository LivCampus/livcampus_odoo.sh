<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_service_action" model="ir.actions.act_window">
        <field name="name">Freight Services</field>
        <field name="res_model">freight.service</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="product_template_service_action" model="ir.actions.act_window">
        <field name="name">Freight Product Services</field>
        <field name="res_model">product.template</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'service')]</field>
    </record>

    <menuitem id="master_data_menu" name="Master Data" sequence="20" parent="bi_freight_management.freight_menu_action">
        <menuitem id="freight_service_menu" name="Services" action="product_template_service_action" sequence="10"/>
        <menuitem id="customers_master_data_menu" name="Customers" action="account.res_partner_action_customer" sequence="20"/>
        <menuitem id="vendors_master_data_menu" name="Vendors" action="account.res_partner_action_supplier" sequence="30"/>
    </menuitem>

    <record id="freight_service_view_form" model="ir.ui.view">
        <field name="name">freight.service.form</field>
        <field name="model">freight.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="vendor_id"/>
                            <field name="service_id"/>
                            <field name="description"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="cost"/>
                            <field name="sale"/>
                            <field name="freight_operation_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_service_view_tree" model="ir.ui.view">
        <field name="name">freight.service.tree</field>
        <field name="model">freight.service</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="vendor_id"/>
                <field name="service_id"/>
                <field name="description"/>
                <field name="currency_id"/>
                <field name="quantity"/>
                <field name="cost"/>
                <field name="sale"/>
            </list>
        </field>
    </record>

</odoo>