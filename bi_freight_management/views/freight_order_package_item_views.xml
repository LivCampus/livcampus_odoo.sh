<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_order_package_item_action" model="ir.actions.act_window">
        <field name="name">Freight Items Lines</field>
        <field name="res_model">freight.order.package.item</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">form</field>
    </record>

    <record id="freight_order_package_item_view_form" model="ir.ui.view">
        <field name="name">freight.order.package.item.form</field>
        <field name="model">freight.order.package.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="description"/>
                            <field name="package_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="operation_value_id"/>
                            <field name="volume"/>
                            <field name="gross_weight"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>