<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_all_shipment_action" model="ir.actions.act_window">
        <field name="name">All Shipments</field>
        <field name="res_model">freight.operation</field>
        <field name="binding_view_types">form</field>
        <field name="context">{'default_type': 'house', 'default_selected_type': False}</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="all_shipment_operation_menu" name="All Shipment" action="freight_all_shipment_action" parent="bi_freight_management.operation_menu" sequence="40"/>

    <record id="freight_all_shipment_view_tree" model="ir.ui.view">
        <field name="name">freight.operation.all.shipment.tree</field>
        <field name="model">freight.operation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="direction"/>
                <field name="transport"/>
                <field name="shipper_id"/>
                <field name="consignee_id"/>
                <field name="gateway_id"/>
                <field name="destination_id"/>
                <field name="agent_id"/>
                <field name="expected_receivable"/>
                <field name="expected_payable"/>
                <field name="expected_margin"/>
                <field name="actual_receivable"/>
                <field name="actual_margin"/>
                <field name="actual_payable"/>
                <field name="receivable_due"/>
                <field name="payable_due"/>
            </list>
        </field>
    </record>
</odoo>