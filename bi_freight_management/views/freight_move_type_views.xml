<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="freight_move_type_action" model="ir.actions.act_window">
        <field name="name">Move Types</field>
        <field name="res_model">freight.move.type</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="freight_move_type_menu" name="Move Type" action="freight_move_type_action"
              parent="bi_freight_management.configuration_menu" sequence="60"/>

    <record id="freight_move_type_view_form" model="ir.ui.view">
        <field name="name">freight.move.type.form</field>
        <field name="model">freight.move.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="freight_move_type_view_tree" model="ir.ui.view">
        <field name="name">freight.move.type.tree</field>
        <field name="model">freight.move.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

</odoo>