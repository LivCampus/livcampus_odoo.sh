<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="freight_service_invoice_bill_wizard_view_form" model="ir.ui.view">
        <field name="name">freight.service.invoice.bill.wizard.form</field>
        <field name="model">freight.service.invoice.bill</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="wizard_type" widget="radio" options="{'vertical': true}" invisible="1"/>
                            <field name="partner_type" widget="radio" options="{'vertical': true}"/>
                            <field name="partner_id" string="Agent" invisible="partner_type != 'agent'" required="partner_type == 'agent'"/>
                            <field name="partner_id" string="Consignee" invisible="partner_type != 'consignee'" required="partner_type == 'consignee'"/>
                            <field name="partner_id" string="Shipper" invisible="partner_type != 'shipper'" required="partner_type == 'shipper'"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="services" string="Services">
                            <field name="freight_service_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_customer_invoice_bill" string="Customer Invoice" class="oe_highlight" type="object"/>
                    <button special="cancel" data-hotkey="z" string="Cancel" />
                </footer>
            </form>
        </field>
    </record>

</odoo>
